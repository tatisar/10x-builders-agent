# Supabase (no spaces around =)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Required for the agent to reply — LangGraph session/checkpoint storage
# Supabase → Connect → Session (port 5432, NOT Transaction/6543)
# Format: postgresql://postgres.[project-ref]:[password]@aws-[n]-[region].pooler.supabase.com:5432/postgres
# If db.[project-ref].supabase.co works on your network you can use that instead (IPv6).
DATABASE_URL=

# OpenRouter
OPENROUTER_API_KEY=

# GitHub OAuth (optional)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Telegram (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_WEBHOOK_BASE_URL=

# OAuth encryption
OAUTH_ENCRYPTION_KEY=

# Bash tool (optional, high-risk)
# Set to "true" to enable execution of bash commands on the server host.
# Leave unset or set to any other value to disable (fail-closed default).
BASH_TOOL_ENABLED=
# Optional override for the bash executable (useful on Windows when PATH points to a broken WSL stub).
# Example: BASH_TOOL_SHELL=C:\Program Files\Git\bin\bash.exe
BASH_TOOL_SHELL=
# Absolute path to use as working directory for bash commands.
# Defaults to process.cwd() if unset or invalid.
BASH_TOOL_CWD=

# File tools (optional, read_file / write_file / edit_file)
# Set FILE_TOOLS_ENABLED=true to enable file read/write/edit operations on the server host.
# Leave unset or set to any other value to disable (fail-closed default).
# Paths passed to file tools can be absolute or relative to the server process working directory,
# matching the same behaviour as the bash tool — no root confinement is enforced.
FILE_TOOLS_ENABLED=

# Scheduled tasks cron runner
# A secret token that Supabase Cron (or any external caller) must send in the
# Authorization header as "Bearer <value>" when hitting /api/cron/scheduled-tasks.
# Leave empty to disable authentication (not recommended for production).
CRON_SECRET=

# Next.js (optional) — extra dev origins for ngrok/custom HTTPS tunnels
# Example: NEXT_ALLOWED_DEV_ORIGINS=https://shuffle-chaplain-jumble.ngrok-free.dev
NEXT_ALLOWED_DEV_ORIGINS=
